<Window x:Class="AcademyWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AcademyWPF"
        mc:Ignorable="d"
        Title="AcademyWPF" Height="450" Width="800" FontFamily="Arial" FontSize="16">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>
        <TabControl Name="tabControl" Grid.Row="0" SelectionChanged="tabControl_SelectionChanged">
            <TabItem Name="tabStudents" Header="Students">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Name="cbStudentsGroup" Grid.Row="0" Grid.Column="0"/>
                    <ComboBox Name="cbStudentsDirection" SelectionChanged="cbStudentsDirection_SelectionChanged" Grid.Row="0" Grid.Column="1"/>
                    <Button Name="buttonAddStudent" Click="buttonAddStudent_Click" Content="Add" Grid.Row="0" Grid.Column="2"/>
                    <DataGrid Name="dgvStudents" Grid.Row="1" Grid.ColumnSpan="3"/>
                </Grid>
            </TabItem>
            <TabItem Name="tabGroups" Header="Groups">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <ComboBox Name="cbGroupsDirection" SelectionChanged="cbGroupsDirection_SelectionChanged" Grid.Row="0"/>
                    <DataGrid Name="dgvGroups" Grid.Row="1"/>
                </Grid>
            </TabItem>
            <TabItem Name="tabDirections"   Header="Directions">   <DataGrid Name="dgvDirections"/>   </TabItem>
            <TabItem Name="tabDisciplines"  Header="Disciplines">  <DataGrid Name="dgvDisciplines"/>  </TabItem>
            <TabItem Name="tabTeachers" Header="Teachers">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Button Name="buttonAddTeacher" Content="Add" Grid.Row="0"/>
                    <DataGrid Name="dgvTeachers" Grid.Row="1"/>
                </Grid>
            </TabItem>
        </TabControl>
        <StatusBar Grid.Row="1" Name="statusBar">
            <StatusBarItem>
                <TextBlock Name="statusBarCount"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
